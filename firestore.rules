rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Helper: check if the user is an admin or manager
    // ========================================
    function isManager() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin'];
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ========================================
    // Announcements collection
    // ========================================
    match /announcements/{docId} {

      // Anyone can read announcements (including unauthenticated guests)
      allow read: if true;

      // Only managers can create, update, or delete announcements
      allow create: if request.auth != null && isManager();
      allow update: if request.auth != null && isManager();
      allow delete: if request.auth != null && isManager();
    }

    // ========================================
    // Users collection
    // ========================================
    match /users/{uid} {

      // Only the user themselves can read their own document (except managers)
      allow read: if request.auth != null && (isOwner(uid) || isManager());

      // Users can update their own data (but not their role)
      allow create: if request.auth != null && isOwner(uid);
      allow update: if request.auth != null && (
        isOwner(uid) && request.resource.data.role == resource.data.role
        ||
        isAdmin()
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // ========================================
    // Deny everything else by default
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
